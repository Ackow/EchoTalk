# 七牛云 Kodo 存储配置 (华东-浙江区)
QINIU_ACCESS_KEY=your_qiniu_access_key
QINIU_SECRET_KEY=your_qiniu_secret_key
QINIU_BUCKET_NAME=your_qiniu_bucket_name
QINIU_DOMAIN=your_qiniu_bucket_domain.com

# 大语言模型配置 (支持多模态与国产/自定义 API，填入其中一个即可自动激活对应客户端)
# 选项 1: DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 选项 2: 小米米魔 (Xiaomi MiMo)
XIAOMI_API_KEY=your_xiaomi_mimo_api_key
XIAOMI_BASE_URL=https://api.xiaomimimo.com/v1
XIAOMI_MODEL=mimo-chat

# 选项 3: OpenAI (默认兼容底座)
OPENAI_API_KEY=mock-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# 向量嵌入模型配置 (RAG 检索模型，如 BAAI/bge-large-en-v1.5)
EMBEDDING_API_KEY=your_embedding_api_key_or_leave_blank_to_share_openai_key
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1/embeddings
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5

# 微软 Azure 语音服务配置 (用于发音评测)
AZURE_SPEECH_KEY=your_azure_speech_key
AZURE_SPEECH_REGION=eastus

# 科大讯飞语音评测配置 (用于流式发音评测)
XFYUN_APP_ID=your_xfyun_app_id
XFYUN_API_KEY=your_xfyun_api_key
XFYUN_API_SECRET=your_xfyun_api_secret

# 百度智能云语音识别配置 (用于语音转文字 STT)
BAIDU_API_KEY=your_baidu_api_key
BAIDU_SECRET_KEY=your_baidu_secret_key

# 数据库连接配置
DATABASE_URL=sqlite:///./echotalk.db
